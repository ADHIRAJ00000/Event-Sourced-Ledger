# Copy this to .env and fill in values
# For local dev (SQLite — no Postgres needed)
LEDGER_DATABASE_URL=sqlite+aiosqlite:///./ledger.db
LEDGER_DATABASE_ECHO=false

LEDGER_SECRET_KEY=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING
LEDGER_ALGORITHM=HS256
LEDGER_ACCESS_TOKEN_EXPIRE_MINUTES=60

LEDGER_DEFAULT_OVERDRAFT_LIMIT=0.0
LEDGER_MAX_TRANSACTION_AMOUNT=1000000.0

LEDGER_DEBUG=false
